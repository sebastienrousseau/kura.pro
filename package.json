{
  "name": "kura.pro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test --config website/scripts/tests/playwright.config.js",
    "test:visual:update": "playwright test --config website/scripts/tests/playwright.config.js --update-snapshots",
    "test:load": "k6 run website/scripts/tests/load.k6.js",
    "test:load:smoke": "k6 run --duration 10s --vus 10 website/scripts/tests/load.k6.js",
    "test:audit": "npm audit --audit-level=high",
    "test:all": "npm test && npm run test:visual",
    "build:css": "tailwindcss -i website/dashboard/input.css -o website/dashboard/tailwind.css --minify",
    "build:manifest": "node website/scripts/generate-manifest.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/cli": "4.2.2",
    "@vitest/coverage-v8": "3.2.4",
    "husky": "9.1.7",
    "tailwindcss": "4.2.2",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "sharp": "0.34.5"
  }
}
