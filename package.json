{
  "name": "kura.pro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test scripts/tests/visual/",
    "test:visual:update": "playwright test scripts/tests/visual/ --update-snapshots",
    "test:load": "k6 run scripts/tests/load.k6.js",
    "test:load:smoke": "k6 run --duration 10s --vus 10 scripts/tests/load.k6.js",
    "test:audit": "npm audit --audit-level=high",
    "test:all": "npm test && npm run test:visual",
    "build:css": "tailwindcss -i dashboard/input.css -o dashboard/tailwind.css --minify",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/cli": "4.2.2",
    "@vitest/coverage-v8": "3.2.4",
    "tailwindcss": "4.2.2",
    "vitest": "3.2.4"
  }
}
